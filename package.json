{
    "name": "sneachta-syntax",
    "displayName": "Sneachta Syntax Highlighter",
    "description": "Sneachta - Syntax highlighting for Snowflake SQL in VSCode. Not affiliated with, endorsed by, or sponsored by Snowflake Inc.",
    "version": "2026.05.26",
    "author": {
        "name": "Daniel O'Keeffe",
        "email": "okeeffdp@tcd.ie"
    },
    "publisher": "okeeffdp",
    "engines": {
        "vscode": "^1.57.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "icon": "assets/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/okeeffdp/snowflake-vscode.git"
    },
    "homepage": "https://github.com/okeeffdp/snowflake-vscode/blob/main/README.md",
    "keywords": [
        "Snowflake SQL",
        "Sneachta",
        "SnowSQL",
        "SQL",
        "Data Warehouse"
    ],
    "contributes": {
        "languages": [
            {
                "id": "snowflake",
                "aliases": [
                    "Snowflake",
                    "snowflake"
                ],
                "extensions": [
                    ".snowql"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "snowflake",
                "scopeName": "source.snowflake",
                "path": "./syntaxes/snowflake.tmLanguage.json"
            }
        ]
    },
    "devDependencies": {
        "js-yaml": "^4.1.0"
    }
}